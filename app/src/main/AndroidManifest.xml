<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.orangetracker">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/_d217111c6684a62c9d12d103db230ae__1_"
        android:label="@string/app_name"
        android:roundIcon="@drawable/_d217111c6684a62c9d12d103db230ae__1_"
        android:supportsRtl="true"
        android:theme="@style/Theme.OrangeTracker"
        tools:targetApi="31">

        <!-- Главная активность (launcher) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Активность подключения -->
        <activity
            android:name=".ConnectionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".MainActivity" />
        </activity>

        <!-- Активность списка устройств -->
        <activity
            android:name=".DevicesActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".MainActivity" />
        </activity>

        <!-- Активность деталей устройства -->
        <activity
            android:name=".DeviceDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".DevicesActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".DevicesActivity" />
        </activity>

    </application>

</manifest>