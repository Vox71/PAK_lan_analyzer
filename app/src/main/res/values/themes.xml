<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Базовая тема -->
    <style name="Theme.OrangeTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/primary_light</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Surface colors -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorSurfaceVariant">#F5F5F5</item>
        <item name="colorOnSurfaceVariant">#757575</item>

        <!-- Background colors -->
        <item name="android:colorBackground">#FAFAFA</item>
        <item name="colorOnBackground">@color/black</item>

        <!-- Error colors -->
        <item name="colorError">@color/status_blocked</item>
        <item name="colorOnError">@color/white</item>

        <!-- Outline colors -->
        <item name="colorOutline">#E0E0E0</item>
        <item name="colorOutlineVariant">#BDBDBD</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Темная тема -->
    <style name="Theme.OrangeTracker.Dark" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_light</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/primary</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">#121212</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">#2D2D2D</item>
        <item name="colorOnSurfaceVariant">#B0B0B0</item>

        <item name="android:colorBackground">#121212</item>
        <item name="colorOnBackground">@color/white</item>

        <item name="colorError">@color/status_blocked</item>
        <item name="colorOnError">@color/white</item>

        <item name="colorOutline">#404040</item>
        <item name="colorOutlineVariant">#606060</item>

        <item name="android:statusBarColor" tools:targetApi="l">#121212</item>
    </style>
</resources>