<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="24dp">

    <!-- Логотип и название (занимает 1/3 экрана) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="@string/app_logo" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tvAppSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_subtitle"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:fontFamily="sans-serif" />
    </LinearLayout>

    <!-- Карточка поиска устройства -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/searching_device"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="sans-serif-medium" />

            <!-- Состояние: Поиск -->
            <LinearLayout
                android:id="@+id/layoutSearching"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="visible">

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminate="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/searching_status"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Состояние: Устройство найдено -->
            <LinearLayout
                android:id="@+id/layoutFound"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/device_found"
                    android:textColor="@color/status_active"
                    android:textSize="16sp"
                    android:drawablePadding="8dp"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/tvDeviceIp"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="192.168.2.1"
                    android:textSize="16sp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_input_disabled"
                    android:enabled="false"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/btnConnect"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/connect_to_device"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:backgroundTint="?attr/colorPrimary"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Состояние: Ошибка -->
            <LinearLayout
                android:id="@+id/layoutError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/device_not_found"
                    android:textColor="@color/status_blocked"
                    android:textSize="16sp"
                    android:drawablePadding="8dp"
                    android:fontFamily="sans-serif" />

                <Button
                    android:id="@+id/btnRetry"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/try_again"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    style="@style/Widget.AppCompat.Button.Borderless" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Карточка ручного подключения -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardManual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/manual_connection"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="sans-serif-medium" />

            <EditText
                android:id="@+id/etManualIp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:hint="@string/ip_address_hint"
                android:textSize="16sp"
                android:inputType="phone"
                android:digits="0123456789."
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/btnManualConnect"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="@string/connect_manual"
                android:textSize="14sp"
                android:textAllCaps="false"
                style="@style/Widget.AppCompat.Button.Borderless" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Версия приложения (прижата к низу) -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:text="@string/app_version"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:fontFamily="sans-serif" />

</LinearLayout>